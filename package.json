{
    "name": "catalog-service",
    "version": "1.0.0",
    "description": "A catalog management service",
    "main": "index.js",
    "scripts": {
        "dev": "cross-env NODE_ENV=development nodemon src/server.ts",
        "build": "tsc",
        "format:check": "prettier . --check",
        "format:fix": "prettier . --write",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "prepare": "husky",
        "test:watch": "jest --watch --runInBand",
        "start": "ts-node src/index.ts",
        "test": "jest --runInBand"
    },
    "author": "Rakesh K <codersgyan@gmail.com>",
    "license": "ISC",
    "devDependencies": {
        "@types/config": "^3.3.5",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.6",
        "@types/http-errors": "^2.0.5",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.6.0",
        "@types/supertest": "^7.2.0",
        "@types/uuid": "^10.0.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.0.0",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "lint-staged": "^16.4.0",
        "nodemon": "^3.1.14",
        "prettier": "3.8.2",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.9",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.2"
    },
    "lint-staged": {
        "*.ts": [
            "npm run lint:fix",
            "npm run format:fix"
        ]
    },
    "dependencies": {
        "config": "^4.4.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "cross-env": "^7.0.3",
        "express": "^5.2.1",
        "express-jwt": "^8.5.1",
        "express-validator": "^7.2.1",
        "http-errors": "^2.0.1",
        "js-yaml": "^4.1.1",
        "jwks-rsa": "^4.0.1",
        "mongoose": "^9.6.2",
        "uuid": "^14.0.0",
        "winston": "^3.19.0"
    }
}
